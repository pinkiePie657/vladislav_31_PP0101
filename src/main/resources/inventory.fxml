<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ru.factory.controller.InventoryController" styleClass="content-area">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Склад готовой продукции"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
        <TextField fx:id="searchField"
                   promptText="Введите наименование..."
                   prefWidth="250"
                   style="-fx-background-radius: 6;"/>
        <Button text="🔍 Поиск"
                onAction="#onSearchClick"
                style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Сбросить"
                onAction="#onResetSearchClick"
                style="-fx-background-color: #95A5A6; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="📤 Экспорт CSV"
                onAction="#onExportClick"
                style="-fx-background-color: #8E44AD; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="+ Поступление"
                onAction="#onIncomingClick"
                style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Отгрузка"
                onAction="#onOutgoingClick"
                style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Наименование" prefWidth="280"/>
            <TableColumn fx:id="quantityColumn" text="Количество (шт)" prefWidth="150"/>
            <TableColumn fx:id="statusColumn" text="Статус" prefWidth="150"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>